# Configuration options

config MAX32664_UPDATER
	bool "MAX32664 Updater"
	default y
	select I2C
	help
		Enable the driver for the Maxim MAX32664 Updater

config MAX32664_UPDATER_INCLUDE_FALLBACK_ARRAYS
	bool "Include fallback firmware arrays"
	depends on MAX32664_UPDATER
	default n
	help
		Include the original firmware arrays as fallback in case
		the filesystem-based firmware files are not available.
		This increases flash usage but provides a backup mechanism.
		Disable this to save maximum flash space.

module = MAX32664_UPDATER
module-str = max32664_updater

source "subsys/logging/Kconfig.template.log_config"
